#!/usr/bin/env zsh
# Single entry point for sesh session/directory picking.
# Usage: tmux-sesh <connect|window|start>
#   connect — pick, then sesh connect (new/existing session)
#   window  — pick, open directories as new tmux windows; sessions via sesh connect
#   start   — attach to "main" if unattached, otherwise pick and connect

mode="${1:-connect}"

pick() {
  sesh list --icons | fzf \
    --ansi --border-label ' sesh ' --prompt '> ' \
    --header 'ctrl-a: all / ctrl-t: tmux / ctrl-x: zoxide / ctrl-d: kill' \
    --bind 'tab:down,btab:up' \
    --bind 'ctrl-a:change-prompt(> )+reload(sesh list --icons)' \
    --bind 'ctrl-t:change-prompt(tmux> )+reload(sesh list --icons -t)' \
    --bind 'ctrl-x:change-prompt(zoxide> )+reload(sesh list --icons -z)' \
    --bind 'ctrl-d:execute(tmux kill-session -t {2..})+reload(sesh list --icons)' \
    --preview-window 'right:55%' \
    --preview 'sesh preview {2..}'
}

case "$mode" in
  start)
    if ! tmux has-session -t main 2>/dev/null || [ -z "$(tmux list-clients -t main)" ]; then
      exec tmux new-session -A -s main
    fi
    selected=$(pick)
    [[ -z "$selected" ]] && exit 0
    sesh connect "$selected"
    ;;
  window)
    selected=$(pick)
    [[ -z "$selected" ]] && exit 0
    dir=$(echo "$selected" | awk '{print $2}')
    dir="${dir/#\~/$HOME}"
    if [[ -d "$dir" ]]; then
      tmux new-window -a -n "$(basename "$dir")" -c "$dir"
    else
      sesh connect "$selected"
    fi
    ;;
  connect)
    selected=$(pick)
    [[ -z "$selected" ]] && exit 0
    sesh connect "$selected"
    ;;
  *)
    echo "Usage: tmux-sesh <connect|window|start>" >&2
    exit 1
    ;;
esac
