#!/usr/bin/env bash
# Manage environment secrets stored in the macOS login keychain.
# Convention: service="env", account=VAR_NAME

set -euo pipefail

SERVICE="env"

usage() {
  cat <<EOF
Usage: keychain-secret <command> [args]

Commands:
  set NAME       Prompt for value and store (overwrites)
  get NAME       Print value to stdout
  ls             List stored secret names
  rm NAME        Delete
EOF
  exit "${1:-0}"
}

cmd="${1:-}"
[ -z "$cmd" ] && usage 1
shift || true

case "$cmd" in
  set)
    name="${1:-}"
    [ -z "$name" ] && { echo "error: name required" >&2; exit 1; }
    printf "Value for %s: " "$name" >&2
    stty -echo; IFS= read -r value; stty echo; echo >&2
    [ -z "$value" ] && { echo "error: empty value" >&2; exit 1; }
    security add-generic-password -U -s "$SERVICE" -a "$name" -w "$value"
    echo "Stored $name" >&2
    ;;
  get)
    name="${1:-}"
    [ -z "$name" ] && { echo "error: name required" >&2; exit 1; }
    security find-generic-password -s "$SERVICE" -a "$name" -w
    ;;
  ls)
    security dump-keychain 2>/dev/null \
      | awk -v s="$SERVICE" '
          /^keychain:/ { svc=""; acct="" }
          /"svce"<blob>=/ { gsub(/.*="|"$/, ""); svc=$0 }
          /"acct"<blob>=/ { gsub(/.*="|"$/, ""); acct=$0; if (svc==s) print acct }
        '
    ;;
  rm)
    name="${1:-}"
    [ -z "$name" ] && { echo "error: name required" >&2; exit 1; }
    security delete-generic-password -s "$SERVICE" -a "$name" >/dev/null
    echo "Deleted $name" >&2
    ;;
  -h|--help|help) usage 0 ;;
  *) usage 1 ;;
esac
