#!/usr/bin/env zsh
# Pick a project under ~/dev and open it in a new tmux window with a layout.
# Usage: tmux-workspace <claude|dev>
#   claude — editor-less: shell left, claude right
#   dev    — nvim left, claude top-right, shell bottom-right

layout="${1:-claude}"

selected_dir=$(cd ~/dev; fd -t d -d 2 . --color=always | fzf --ansi --highlight-line -e)
[[ -z "$selected_dir" ]] && { echo "No directory selected"; exit 0 }

full_path="$HOME/dev/$selected_dir"
dir_basename=$(basename "$selected_dir")

tmux new-window -a -n "$dir_basename" -c "$full_path" -k

case "$layout" in
  claude)
    tmux split-window -h -c "$full_path"
    tmux send-keys "mise exec -- claude" Enter
    tmux select-pane -L
    ;;
  dev)
    tmux split-window -h -c "$full_path"
    tmux split-window -v -c "$full_path"
    tmux send-keys -t 0 "nvim ." Enter
    tmux send-keys -t 1 "claude" Enter
    tmux select-pane -t 0
    ;;
  *)
    echo "Usage: tmux-workspace <claude|dev>" >&2
    exit 1
    ;;
esac
