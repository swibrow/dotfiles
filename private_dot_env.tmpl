{{- /* Proton Pass integration for secrets */ -}}
{{- /* To set up: install proton-pass-cli, authenticate, then replace ITEM_ID values */ -}}
{{- /* Usage: protonpass "ITEM_ID" returns the password for the given item */ -}}
{{- /* Run `proton-pass item list` to find your item IDs */ -}}

# GitHub
# GH_TOKEN={{ protonPass "ITEM_ID_FOR_GH_TOKEN" }}
# GITHUB_ACCESS_TOKEN={{ protonPass "ITEM_ID_FOR_GITHUB_ACCESS_TOKEN" }}

# Google
# GOOGLE_STUDIO_APIKEY={{ protonPass "ITEM_ID_FOR_GOOGLE_STUDIO" }}

# Jira
# JIRA_API_TOKEN={{ protonPass "ITEM_ID_FOR_JIRA" }}

# OpenAI
# OPENAI_API_KEY={{ protonPass "ITEM_ID_FOR_OPENAI" }}

# Toggl
# TOGGL_API_TOKEN={{ protonPass "ITEM_ID_FOR_TOGGL" }}

# Anthropic
# ANTHROPIC_API_KEY={{ protonPass "ITEM_ID_FOR_ANTHROPIC" }}
