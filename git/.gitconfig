[init]
	defaultBranch = main
[user]
	email = 15628653+swibrow@users.noreply.github.com
	name = Samuel
	signingkey = 28257C9F
[commit]
	gpgSign = true
[tag]
	gpgSign = true
[push]
	autoSetupRemote = true
[core]
	editor = nvim
	excludesfile = ~/.gitignore
[pull]
	rebase = true
[alias]
	housekeeping = "!git fsck && git fsck --unreachable && git gc --aggressive --prune && git prune && git prune-packed"
	wipeout = "!git branch | sed 's/^[*]* *//' | gum choose --no-limit --header 'Wipeout which branches?' | xargs git branch -D"

[url "git@github.com:"]
	insteadOf = "https://github.com/"
