{{ if lookPath "swiftc" -}}
#!/bin/bash
set -euo pipefail

# recompile when the source changes: {{ include "dot_local/bin/keyfreq.swift" | sha256sum }}

SRC="${HOME}/.local/bin/keyfreq.swift"
OUT="${HOME}/.local/bin/keyfreq"
PLIST="${HOME}/Library/LaunchAgents/com.swibrow.keyfreq.plist"

if [ -f "$SRC" ]; then
    echo "[INFO] Compiling keyfreq..."
    mkdir -p "${HOME}/.local/bin" "${HOME}/.local/share/keyfreq"
    swiftc -O "$SRC" -o "$OUT"

    if [ -f "$PLIST" ]; then
        launchctl unload "$PLIST" 2>/dev/null || true
        launchctl load "$PLIST" 2>/dev/null || true
    fi
fi
{{ end -}}
