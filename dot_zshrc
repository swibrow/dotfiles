# .zshrc — target: <300ms startup
# No plugin manager. Carapace for completions, atuin for history.

[[ $- != *i* ]] && return
[[ -n "$TMUX" ]] && export TERM="screen-256color"

# Homebrew (fallback if not set by zprofile)
[[ -z "$HOMEBREW_PREFIX" ]] && export HOMEBREW_PREFIX="/opt/homebrew"

# PATH
export PATH="$HOMEBREW_PREFIX/bin:$HOMEBREW_PREFIX/sbin:$HOME/bin:${KREW_ROOT:-$HOME/.krew}/bin:$HOME/go/bin:$HOME/.local/bin:/usr/local/opt/ruby/bin:/opt/homebrew/opt/ruby/bin:$HOME/.tfenv/bin:/opt/homebrew/opt/mariadb-connector-c/bin:$HOME/.bun/bin:$PATH"
export MANPATH="$HOMEBREW_PREFIX/share/man:$MANPATH"
export INFOPATH="$HOMEBREW_PREFIX/share/info:$INFOPATH"

# Environment
export STARSHIP_CONFIG="$HOME/.config/starship/starship.toml"
export HOMEBREW_BUNDLE_FILE="$HOME/.config/homebrew/Brewfile"
export HOMEBREW_BUNDLE_LOCK=1
export LANG=en_US.UTF-8
export AWS_VAULT_BACKEND=keychain
export K9S_CONFIG_DIR="$HOME/.config/k9s"
export TF_PLUGIN_CACHE_DIR="$HOME/.terraform.d/plugin-cache"
export GPG_TTY=$(tty)
export EDITOR='vim'
export CARAPACE_BRIDGES='zsh,fish,bash,inshellisense'
export BUN_INSTALL="$HOME/.bun"
export FZF_CTRL_T_OPTS="--preview='bat --color=always --style=header,grid --line-range :500 {}'"
export FZF_DEFAULT_OPTS=" \
--color=bg+:#313244,bg:#1e1e2e,spinner:#f5e0dc,hl:#f38ba8 \
--color=fg:#cdd6f4,header:#f38ba8,info:#cba6f7,pointer:#f5e0dc \
--color=marker:#b4befe,fg+:#cdd6f4,prompt:#cba6f7,hl+:#f38ba8 \
--color=selected-bg:#45475a \
--multi"

# History
HISTFILE="$HOME/.zsh_history"
HISTSIZE=100000
SAVEHIST=100000
setopt share_history hist_ignore_all_dups hist_ignore_space hist_reduce_blanks

# Zsh options
setopt auto_cd auto_pushd pushd_ignore_dups pushd_silent
setopt interactive_comments
setopt no_beep

# Completions fpath
fpath=($HOMEBREW_PREFIX/share/zsh/site-functions $fpath)

# --- Cache helper: source cached tool output, regenerate when binary updates ---
_zsh_cache="$HOME/.cache/zsh"
[[ -d "$_zsh_cache" ]] || mkdir -p "$_zsh_cache"

_cached_eval() {
  local name=$1; shift
  local cache="$_zsh_cache/$name.zsh"
  local bin="${commands[$name]:-}"
  if [[ -n "$bin" ]]; then
    if [[ ! -f "$cache" || "$bin" -nt "$cache" ]]; then
      eval "$@" > "$cache" 2>/dev/null
    fi
    source "$cache"
  fi
}

# Prompt (synchronous, required for first render)
_cached_eval starship starship init zsh

# Compinit (needed before carapace and completions)
autoload -Uz compinit
if [[ -f "$_zsh_cache/.zcompdump" && "$_zsh_cache/.zcompdump" -nt "$_zsh_cache/.zcompdump.zwc" ]]; then
  compinit -d "$_zsh_cache/.zcompdump"
  zcompile "$_zsh_cache/.zcompdump"
else
  compinit -C -d "$_zsh_cache/.zcompdump"
fi

# Cached tool inits (~1ms each to source)
_cached_eval fzf fzf --zsh
_cached_eval atuin atuin init zsh --disable-up-arrow
_cached_eval carapace carapace _carapace
_cached_eval zoxide zoxide init zsh
_cached_eval mise mise activate zsh
_cached_eval wt wt config shell init zsh
_cached_eval kubectl kubectl completion zsh
_cached_eval helm helm completion zsh
_cached_eval talosctl talosctl completion zsh

# Completion style
zstyle ':completion:*' format $'\e[2;37mCompleting %d\e[m'

# Override carapace's just completer — carapace escapes colons which breaks :: module completions
_just_completion() {
    local -a recipes
    recipes=(${(s: :)$(just --summary 2>/dev/null)})
    compadd -X 'recipes' -- "${recipes[@]}"
}
compdef _just_completion just

# Functions and aliases
source $HOME/.config/zsh/functions/general.zsh
source $HOME/.config/zsh/functions/kubectl.zsh
source $HOME/.config/zsh/functions/terraform.zsh
source $HOME/.config/zsh/functions/talos.zsh
source $HOME/.config/zsh/aliases.zsh

alias tm='task-master'

# Plugins (from brew)
source $HOMEBREW_PREFIX/share/zsh-autosuggestions/zsh-autosuggestions.zsh
source $HOMEBREW_PREFIX/share/zsh-fast-syntax-highlighting/fast-syntax-highlighting.plugin.zsh

# Up/Down arrow: prefix history search (type "k" then up → matches "kubectl …")
bindkey '^[[A' history-search-backward
bindkey '^[[B' history-search-forward

# Background tasks
{
  pgrep -x gpg-agent >/dev/null || gpgconf --launch gpg-agent
} &!

unset _zsh_cache
